# =============================================================================
# .gitignore Template fuer Software Entwicklung Projekte
# Kopieren und als .gitignore im Projektroot ablegen
# Projektspezifische Eintraege am Ende anfuegen
# =============================================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
dist/
build/

# ---- Virtuelle Umgebungen ----
venv/
.venv/
env/
.env/

# ---- BACH Interne Steuerungsdateien (NIEMALS in Git!) ----
AUFGABEN.txt
AUFGABEN.txt.txt
TEST.txt
TESTS.txt
TESTERGEBNISSE.txt
BUGREPORT.md
BUGREPORT_*.md
DIAGNOSE_REPORT.md
ANALYSE_*.md

# ---- Persoenliche / Sensible Daten ----
_USER/
.env
.env.*
credentials.json
client_secret*.json
token.json
*.pem
*.key
keyring/

# ---- Build-Artefakte & Releases ----
releases/
*.exe
*.msi
*.msix
*.appx
*.spec

# ---- IDE & Editoren ----
.claude/
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Betriebssystem ----
desktop.ini
Thumbs.db
.DS_Store
ehthumbs.db

# ---- Standard-Patterns ----
PLAN.txt
_archive/
_private/
*.log

# ---- Entwicklungs- und Backup-Ordner ----
_BACKUP/
_DEV/
_WARTUNG/
_alt/
_archiv/

# ---- Projektspezifisch ----
DIAGNOSE_REPORT.json
TESTBERICHT.txt

# Test-Dateien im Root (src/tests sind getrackt)
/test*.py
/test*.bat
